@dyn as posix { variadic fn printf(&raw ui1) -> si4; }

// §7.9 labelled loops: `'name:` labels a loop; `break 'name` / `continue
// 'name` target it from within a nested loop.
fn main() -> ui1 {
    // break 'outer from an inner loop on a 2-D search.
    mut found: si4 = -1;
    mut i: si4 = 0;
    'outer: while i < 5 {
        mut j: si4 = 0;
        while j < 5 {
            if i * 10 + j == 23 {
                found = i * 10 + j;
                break 'outer;
            }
            j += 1;
        }
        i += 1;
    }
    airside { posix::printf("found=%d i=%d\n\0".ptr, found, i); }  // 23 2

    // continue 'rows skips the rest of the inner loop for that row.
    mut sum: si4 = 0;
    mut a: si4 = 0;
    'rows: while a < 3 {
        mut b: si4 = 0;
        a += 1;
        while b < 3 {
            b += 1;
            if b == 2 { continue 'rows; }   // count only b == 1 per row
            sum += b;
        }
    }
    airside { posix::printf("sum=%d\n\0".ptr, sum); }   // 3
    return 0;
}
