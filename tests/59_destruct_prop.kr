@dyn as posix { variadic fn printf(%ui1) -> si4; }

// §8.11 destruct propagation: a type with no `with destruct` of its own
// still satisfies `destruct` when a field/payload does, and the implicit
// destructor destroys those parts. Struct fields go in reverse declaration
// order; bindings within a scope also go in reverse declaration order (LIFO).
struct sentry { id: si4 } with destruct {
    airside { posix::printf("drop %d\n\0".ptr, self.id); }
};

// propagation-only: no destructor body, yet holds two guards.
struct pair { x: sentry, y: sentry }

// own destructor + a sentry field: the block runs first, then the field.
struct wrapped { g: sentry } with destruct {
    airside { posix::printf("wrap\n\0".ptr); }
};

// enum whose active variant carries a destruct payload.
enum box { Empty, Full { sentry } }

fn main() -> ui1 {
    let g1: sentry = sentry { id = 1 };
    let g2: sentry = sentry { id = 2 };
    let g3: sentry = sentry { id = 3 };
    let g4: sentry = sentry { id = 4 };
    let p: pair    = pair { x = g1, y = g2 };   // g1,g2 transferred into p
    let w: wrapped = wrapped { g = g3 };        // g3 transferred into w
    let b: box     = box::Full { g4 };          // g4 transferred into b
    airside { posix::printf("body\n\0".ptr); }
    return 0;
    // g1..g4 are moved, so not dropped. LIFO over live bindings: b, w, p.
    //   b -> payload sentry(4):            drop 4
    //   w -> block, then field sentry(3):  wrap, drop 3
    //   p -> fields y(2), x(1) reversed:  drop 2, drop 1
}
