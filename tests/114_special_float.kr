@dyn as posix { variadic fn printf(%ui1) -> si4; }

// §3.5.2 special floating-point literals: `0nanq` is a quiet NaN (sign 0,
// payload 0), `0nans` a signalling NaN (payload 1), `0inf` positive
// infinity; all accept a float suffix and negate via unary `-`.
fn main() -> ui1 {
    let n = 0nanq;                   // fe11m52 default
    let i = 0inf;
    let n32: fe8m23 = 0nanqfe8m23;   // suffixed
    let ni = -0inf;                  // unary negation
    airside {
        posix::printf("i=%f ni=%f\n\0".ptr, i, ni);
    }
    // §4.4.3 total order: infinity still compares above any finite
    // value; a positive quiet NaN compares above everything, including
    // +inf; a negative quiet NaN compares below -inf.
    let big: bool = i > 1.0e300;
    let above: bool = n > i;
    let neg_below: bool = -0nanq < ni;
    return if big
           then (if above then (if neg_below then 42 else 1) else 2)
           else 3;
}
