@dyn as posix { variadic fn printf(&raw ui1) -> si4; }
// §7.2.3 extract-assignment: `place <- e else { }` copies the success payload
// into an existing mut place; the diverging else runs on failure.
fn main() -> ui1 {
    mut total: si4 = 0;
    let ok:  verdict.<si4, si4> = verdict::Pass { 42 };
    total <- ok else err { total = -1; };       // total becomes 42
    airside { posix::printf("total=%d\n\0".ptr, total); }   // 42

    mut other: si4 = 100;
    let bad: verdict.<si4, si4> = verdict::Fail { 7 };
    other <- bad else err {                       // failure path
        airside { posix::printf("failed err=%d\n\0".ptr, err); }   // 7
        other = 999;
    };
    airside { posix::printf("other=%d\n\0".ptr, other); }   // 999
    return 0;
}
