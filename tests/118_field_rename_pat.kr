@dyn as posix { variadic fn printf(%ui1) -> si4; }

// §5.10.2 named `binding = field` payload patterns: the leading name is the
// binding, the following name is the field it resolves to (by name, not
// position), so entries may appear in any order with a differently-named
// binding.
enum shape { Rect { w: si4, h: si4 }, Sq { side: si4 } }

fn area(s: shape) -> si4 {
    return match s {
        shape::Rect { height = h, width = w } = width * height,  // reordered
        shape::Sq { s = side } = s * s,
        #wild# = 0,
    };
}

fn main() -> ui1 {
    let r: shape = shape::Rect { w = 6, h = 7 };
    let q: shape = shape::Sq { side = 5 };
    airside { posix::printf("r=%d q=%d\n\0".ptr, area(r), area(q)); }  // 42 25
    return area(r) as ui1;
}
