@dyn as posix { variadic fn printf(&raw ui1) -> si4; }

// §8.4 inner-scope destruction timing: an object declared inside a block is
// destroyed at that block's textual end — before any enclosing-scope object
// — and an early `return` destroys exactly the objects live at that point.
struct sentry { id: si4 } with destruct {
    airside { posix::printf("drop %d\n\0".ptr, self.id); }
};

// Early return from inside a nested block: y then x drop on the taken path.
fn early(flag: bool) -> ui1 {
    let x: sentry = sentry { id = 7 };
    if flag {
        let y: sentry = sentry { id = 8 };
        return 0;                 // drops y(8), x(7) — both live here
    }
    return 1;                     // drops x(7) only
}

fn main() -> ui1 {
    let a: sentry = sentry { id = 1 };
    airside {
        let b: sentry = sentry { id = 2 };
        posix::printf("in-air\n\0".ptr);
    }                             // b drops at airside-block end: drop 2
    airside { posix::printf("mid\n\0".ptr); }
    if true {
        let c: sentry = sentry { id = 3 };
        airside { posix::printf("in-if\n\0".ptr); }
    }                             // c drops at if-block end: drop 3
    airside { posix::printf("--early(true)--\n\0".ptr); }
    let r: ui1 = early(true);     // drop 8, drop 7
    airside { posix::printf("--early(false)--\n\0".ptr); }
    let s: ui1 = early(false);    // drop 7
    airside { posix::printf("end\n\0".ptr); }
    return 0;                     // a drops at fn end: drop 1
}
