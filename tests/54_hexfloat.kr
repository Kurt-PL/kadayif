@dyn as posix { variadic fn printf(%ui1) -> si4; }

// §3.5.2 hexadecimal floating-point literals: `0x` significand with a
// fractional part and/or a binary exponent (`p`/`P`, power of two).
fn main() -> ui1 {
    let a: fe11m52 = 0x1.8p1;          // (1 + 8/16) * 2^1   = 3.0
    let b: fe11m52 = 0x1p4;            // 1 * 2^4            = 16.0
    let c: fe11m52 = 0x1P-2;           // 1 * 2^-2           = 0.25
    let d: fe11m52 = 0xA.8p0;          // (10 + 8/16) * 2^0  = 10.5
    let e: fe11m52 = 0x1.0p10;         // 1 * 2^10           = 1024.0
    airside { posix::printf("a=%.4f b=%.4f c=%.4f d=%.4f e=%.4f\n\0".ptr,
        a, b, c, d, e); }
    let f: fe11m52 = 0x1.8p1fe11m52;   // suffixed (f64)     = 3.0
    airside { posix::printf("f=%.4f\n\0".ptr, f); }
    return 0;
}
