@dyn as posix { variadic fn printf(&raw ui1) -> si4; }

// §10.2/§10.3 `@add "path" as geo;` — imports another source unit (resolved
// relative to this file). The `as geo` namespace is mandatory: only geo.kr's
// `pub` declarations are reachable, and only through `geo::point`/
// `geo::area` — bare `point`/`area` do not exist in this unit's scope.
// Transitive imports and diamond dedup are exercised in the manual
// multi-file checks.
@add "85_lib/geo.kr" as geo;

fn main() -> ui1 {
    let p: geo::point = geo::point { x = 6, y = 7 };   // struct from geo.kr
    let a: si4 = geo::area(p);                          // fn from geo.kr
    airside { posix::printf("area=%d\n\0".ptr, a); }   // 42
    return 0;
}
