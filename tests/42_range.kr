@dyn as posix { variadic fn printf(&raw ui1) -> si4; }

// §4.8 range types: the `..` / `..=` operators produce the intrinsic range
// types range_ex.<T> / range_in.<T> (fields `start`, `end`) — built into the
// compiler like [T; N], not declared. T is inferred from the operands
// (suffix / float default / `as`; a bare integer literal defaults to saddr,
// and adopts the other bound's type when that one is explicit).
fn main() -> ui1 {
    // Exclusive range, element type inferred saddr (unsuffixed int).
    let re = 0..10;                       // range_ex.<saddr>
    airside {
        posix::printf("ex start=%lld end=%lld\n\0".ptr, re.start, re.end);
    }                                                     // 0 10

    // Inclusive range, element type pinned to ui1 by the suffix.
    let ri = 0..=255ui1;                  // range_in.<ui1>
    airside {
        posix::printf("in start=%u end=%u\n\0".ptr, ri.start, ri.end);
    }                                                     // 0 255

    // A typed exclusive range, iterated manually (Kurt composes iteration
    // from while + the range's start/end, §7.5/§7 informative).
    let r3 = 0si4..5si4;                  // range_ex.<si4>
    mut i: si4 = r3.start;
    mut sum: si4 = 0;
    while i < r3.end {
        sum += i;                                         // 0+1+2+3+4
        i += 1;
    }
    airside { posix::printf("exsum=%d\n\0".ptr, sum); }   // 10

    // Inclusive iteration over a small ui1 range.
    let r4 = 1ui1..=5ui1;                 // range_in.<ui1>
    mut j: ui1 = r4.start;
    mut s2: si4 = 0;
    while j <= r4.end {
        s2 += j as si4;                                   // 1+2+3+4+5
        j += 1;
    }
    airside { posix::printf("insum=%d\n\0".ptr, s2); }    // 15

    // Variable bounds: the element type is synthesised from the operands
    // (no literal needed). Both bounds are si4 here.
    let lo: si4 = 3;
    let hi: si4 = 9;
    let rv = lo..hi;                      // range_ex.<si4>
    airside { posix::printf("var %d %d\n\0".ptr, rv.start, rv.end); }  // 3 9

    // Explicit annotation drives the element type.
    let ra: range_ex.<si4> = 0..10;
    airside { posix::printf("ann %d %d\n\0".ptr, ra.start, ra.end); }  // 0 10

    // Float range: bare floats default to fe11m52 (§4.3). Read back via an
    // integer cast (§6.8.4).
    let rf = 2.0..7.5;                    // range_ex.<fe11m52>
    let fl: si4 = rf.start as si4;
    let fh: si4 = rf.end as si4;
    airside { posix::printf("flo %d %d\n\0".ptr, fl, fh); }            // 2 7
    return 0;
}
