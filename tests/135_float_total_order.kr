@dyn as posix { variadic fn printf(&raw ui1) -> si4; }

// §4.4.3 floating-point comparison is the ISO/IEC 60559:2020 total
// order: NegQNN < NegSNN < NegInf < NegScl < NegZro < PosZro < PosScl
// < PosInf < PosSNN < PosQNN; NaNs order by payload within a class.

fn b2i(b: bool) -> si4 { return if b then 1 else 0; }

fn main() -> ui1 {
    let nz: fe11m52 = -0.0;
    let pz: fe11m52 = 0.0;
    let q = 0nanq;
    let s = 0nans;
    let i = 0inf;
    airside {
        posix::printf("%d%d%d%d%d%d%d%d%d%d%d%d%d\n\0".ptr,
            b2i(-5.0 < -1.0),           // 1 — NegScl orders by value
            b2i(nz < pz),               // 1 — -0.0 < +0.0
            b2i(nz == pz),              // 0 — sign distinguishes zero
            b2i(nz != pz),              // 1
            b2i(s < q),                 // 1 — +sNaN below +qNaN
            b2i(q > i),                 // 1 — +qNaN above +inf
            b2i(s > i),                 // 1 — +sNaN above +inf too
            b2i(-q < -i),               // 1 — NegQNN below NegInf
            b2i(-q < -s),               // 1 — NegQNN below NegSNN
            b2i(0nanq'1 < 0nanq'2),     // 1 — payload orders later (+)
            b2i(-0nanq'2 < -0nanq'1),   // 1 — payload orders earlier (-)
            b2i(q == 1.0),              // 0 — NaN equals nothing else
            b2i(0nanqfe8m23 > 0inffe8m23)); // 1 — fe8m23 path
        // 1101111111101
    }
    return 0;
}
