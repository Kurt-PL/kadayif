@dyn as posix { variadic fn printf(%ui1) -> si4; }

// §9.3.1 associated-type DEFAULT: the trait declares `type Item = si4;` with a
// default, and the impl OMITS `type Item = ...`. The method signature refers to
// `selftype::Item`, which must fall back to the trait's declared default (si4).
trait T {
    type Item = si4;
    fn get(&self) -> selftype::Item;
}

struct x { v: si4 }

impl x as T {
    // no `type Item = ...` here — inherits the trait default `si4`
    fn get(&self) -> selftype::Item { return 7; }
}

fn main() -> ui1 {
    let b: x = x { v = 0 };
    airside { posix::printf("got=%d\n\0".ptr, b.get()); }   // 7
    return 7;
}
