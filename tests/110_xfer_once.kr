@dyn as posix { variadic fn printf(&raw ui1) -> si4; }

// §9.9.3 `xfer` closures may be invoked AT MOST ONCE. Invoking such a closure
// consumes its `with destruct` captures, so the compiler treats the call as a
// transfer of the closure binding: a second call to the same in-scope binding
// is a §8.8.2 use-after-transfer failure. This test exercises the *legal*
// single-invocation path (invoking exactly once), which must still translate
// and run: the captured `sentry` is dropped exactly once (by the env's
// destructor at scope exit).
struct sentry { id: si4 } with destruct {
    airside { posix::printf("drop %d\n\0".ptr, self.id); }
};

fn main() -> ui1 {
    let g: sentry = sentry { id = 7 };
    // `g` (with destruct) is transferred into the closure; `xfer` required.
    let run = xfer /.k: si4/ -> si4 {
        return g.id + k;         // reads the captured sentry
    };
    let r: si4 = run(35);        // 7 + 35 = 42 — the single, legal invocation
    airside { posix::printf("r=%d\n\0".ptr, r); }
    return 0;                    // env destructor drops the captured sentry once
}
