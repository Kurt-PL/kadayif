@dyn as posix { variadic fn printf(&raw ui1) -> si4; }

// §5.10.1 `#wild#(name)`: the type-destroying catch-all binds the matched
// value's raw representation as a `&[ui1]` cell slice.

enum code {
    A = 1,
    B = 2
}

struct pair { lo: ui1, hi: ui1 }

fn main() -> ui1 {
    let c: code = code::A;
    let p = pair { lo = 7, hi = 9 };
    mut len1: uaddr = 0;
    mut first: ui4 = 0;
    mut len2: uaddr = 0;
    mut sum: ui4 = 0;
    airside {
        // scalar (unit-enum) scrutinee: no declared #wild#, so the
        // #wild#(name) arm is what makes the match exhaustive.
        match c {
            code::B     = 0,
            #wild#(raw) = {
                len1  = raw.len;
                first = *(raw.ptr) as ui4;
                express 1;
            },
        };
        // aggregate scrutinee: the slice spans the whole object.
        match p {
            #wild#(raw) = {
                len2 = raw.len;
                sum  = (*(raw.ptr) + *(raw.ptr + 1)) as ui4;
                express 2;
            },
        };
        posix::printf("l1=%lu f=%u l2=%lu s=%u\n\0".ptr,
                      len1, first, len2, sum);
        // l1=1 f=1 l2=2 s=16
    }
    return 0;
}
