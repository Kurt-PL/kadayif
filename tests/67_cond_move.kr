@dyn as posix { variadic fn printf(&raw ui1) -> si4; }

// §8.8/§8.11 conditional-move drop flags: a binding moved on only some
// control-flow paths is destroyed exactly once. `g` is moved into `sink`
// only when `cond` is true; the runtime drop flag makes the scope-exit
// destructor run iff the move did not happen.
struct guard { id: si4 } with destruct {
    airside { posix::printf("drop %d\n\0".ptr, self.id); }
};

fn sink(g: guard) -> void {
    airside { posix::printf("sink %d\n\0".ptr, g.id); }
}                                   // sink destroys its parameter g

fn test(cond: bool) -> void {
    let g: guard = guard { id = 5 };
    if cond {
        sink(g);                    // g transferred into sink (cond path only)
    }
    // scope exit: g is destroyed here iff cond was false (flag is still set)
}

fn main() -> ui1 {
    airside { posix::printf("[true]\n\0".ptr); }
    test(true);                     // moved -> sink drops; scope-exit skips
    airside { posix::printf("[false]\n\0".ptr); }
    test(false);                    // not moved -> scope-exit drops
    return 0;
}
